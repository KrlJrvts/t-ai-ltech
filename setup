#!/usr/bin/env bash
# Setup — build browse binary and register all skills for local skill installs.
set -euo pipefail

STACK_DIR="$(cd "$(dirname "$0")" && pwd)"
STACK_NAME="$(basename "$STACK_DIR")"
SKILLS_DIR="$(dirname "$STACK_DIR")"
BROWSE_BIN="$STACK_DIR/browse/dist/browse"
BROWSE_ENGINE="${BROWSE_BROWSER:-chromium}"

if ! command -v bun >/dev/null 2>&1; then
  echo "setup failed: Bun is required but was not found in PATH" >&2
  exit 1
fi

normalize_browser() {
  case "${1:-chromium}" in
    chromium|chrome|edge|firefox) echo "$1" ;;
    msedge) echo "edge" ;;
    *)
      echo "setup failed: unsupported BROWSE_BROWSER '$1' (use chromium, chrome, edge, or firefox)" >&2
      exit 1
      ;;
  esac
}

BROWSE_ENGINE="$(normalize_browser "$BROWSE_ENGINE")"

ensure_playwright_browser() {
  (
    cd "$STACK_DIR"
    BROWSE_ENGINE="$BROWSE_ENGINE" bun --eval '
      import { chromium, firefox } from "playwright";
      const target = process.env.BROWSE_ENGINE || "chromium";
      const launch =
        target === "firefox" ? () => firefox.launch({ headless: true }) :
        target === "chrome" ? () => chromium.launch({ headless: true, channel: "chrome" }) :
        target === "edge" ? () => chromium.launch({ headless: true, channel: "msedge" }) :
        () => chromium.launch({ headless: true });
      const browser = await launch();
      await browser.close();
    '
  ) >/dev/null 2>&1
}

install_playwright_browser() {
  (
    cd "$STACK_DIR"
    case "$BROWSE_ENGINE" in
      firefox) bunx playwright install firefox ;;
      chrome) bunx playwright install chrome ;;
      edge) bunx playwright install msedge ;;
      *) bunx playwright install chromium ;;
    esac
  )
}

# 1. Build browse binary if needed (smart rebuild: stale sources, package.json, lock)
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$STACK_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$STACK_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$STACK_DIR/bun.lock" ] && [ "$STACK_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  echo "Building browse binary..."
  (
    cd "$STACK_DIR"
    bun install
    bun run build
  )
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "setup failed: browse binary missing at $BROWSE_BIN" >&2
  exit 1
fi

# 2. Ensure the selected Playwright browser is available
if ! ensure_playwright_browser; then
  echo "Installing Playwright browser support for '$BROWSE_ENGINE'..."
  install_playwright_browser
fi

if ! ensure_playwright_browser; then
  echo "setup failed: Playwright browser '$BROWSE_ENGINE' could not be launched" >&2
  exit 1
fi

# 3. Only create skill symlinks if we're inside a .claude/skills directory
SKILLS_BASENAME="$(basename "$SKILLS_DIR")"
if [ "$SKILLS_BASENAME" = "skills" ]; then
  linked=()
  for skill_dir in "$STACK_DIR"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      # Skip node_modules
      [ "$skill_name" = "node_modules" ] && continue
      target="$SKILLS_DIR/$skill_name"
      # Create or update symlink; skip if a real file/directory exists
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "$STACK_NAME/$skill_name" "$target"
        linked+=("$skill_name")
      fi
    fi
  done

  echo "$STACK_NAME ready."
  echo "  browse: $BROWSE_BIN"
  echo "  browser: $BROWSE_ENGINE"
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
else
  echo "$STACK_NAME ready."
  echo "  browse: $BROWSE_BIN"
  echo "  browser: $BROWSE_ENGINE"
  echo "  (skipped skill symlinks — not inside .claude/skills/)"
fi
